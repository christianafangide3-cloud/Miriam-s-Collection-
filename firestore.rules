rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Admin Entity Validation
    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string
        && data.email.size() > 0
        && data.createdAt == request.time;
    }

    // Entities Validation
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 256
        && data.createdAt == request.time;
    }
    
    function isValidUserUpdate() {
       return incoming().email == existing().email 
          && incoming().createdAt == existing().createdAt;
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['productId', 'savedAt'])
        && data.keys().size() == 2
        && data.productId is string
        && data.savedAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() > 0
        && data.price is number
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt'])
        && data.keys().size() == 6
        && data.productId is string
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    // Admins Collection
    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isValidId(userId) && isOwner(userId);
      
      allow create: if isVerified() 
        && isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming());
        
      allow update: if isVerified() 
        && isOwner(userId) 
        && isValidId(userId)
        && isValidUserUpdate()
        && incoming().diff(existing()).affectedKeys().size() == 0; // Nothing mutable
        
      allow delete: if isVerified() && isOwner(userId) && isValidId(userId);

      // Wishlist Subcollection
      match /wishlist/{docId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(docId);
        
        allow list: if isOwner(userId) && isValidId(userId); 
        
        allow create: if isVerified()
          && isOwner(userId)
          && isValidId(userId)
          && isValidId(docId)
          && isValidWishlistItem(incoming())
          && existsAfter(/databases/$(database)/documents/users/$(userId));
          
        allow update: if false; // Wishlist items are immutable
        
        allow delete: if isVerified()
          && isOwner(userId)
          && isValidId(userId)
          && isValidId(docId);
      }
    }

    // Products Collection
    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
      
      allow create: if isAdmin() 
        && isValidId(productId)
        && isValidProduct(incoming());
        
      allow update: if isAdmin() 
        && isValidId(productId)
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isAdmin() && isValidId(productId);

      match /reviews/{reviewId} {
        allow get: if isValidId(reviewId);
        allow list: if true;

        allow create: if isVerified()
          && isValidId(reviewId)
          && isValidReview(incoming())
          && existsAfter(/databases/$(database)/documents/products/$(productId));

        allow update: if isVerified()
          && isValidId(reviewId)
          && isOwner(existing().userId)
          && incoming().createdAt == existing().createdAt
          && incoming().productId == existing().productId
          && incoming().userId == existing().userId
          && incoming().userName == existing().userName
          && incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'rating']);

        allow delete: if (isVerified() && isOwner(existing().userId)) || isAdmin();
      }
    }
  }
}
